{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://llm-ir.org/schema/llm-ir.v0.schema.json",
  "title": "LLM-IR v0",
  "description": "A minimal intermediate representation for multilingual, privacy-aware human communication.",
  "type": "object",
  "required": ["schema", "source", "intent", "meaning"],
  "additionalProperties": false,
  "$defs": {
    "localizedText": {
      "type": "object",
      "description": "Language-tagged text. Keys should be BCP 47 language tags or 'und' for undetermined.",
      "minProperties": 1,
      "additionalProperties": {
        "type": "string"
      }
    },
    "concept": {
      "type": "object",
      "required": ["id"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "A stable language-neutral concept identifier, such as affect:frustration."
        },
        "glosses": {
          "$ref": "#/$defs/localizedText"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "marker": {
      "type": "object",
      "required": ["id"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "evidence": { "type": "string" },
        "glosses": {
          "$ref": "#/$defs/localizedText"
        }
      }
    }
  },
  "properties": {
    "schema": {
      "const": "llm-ir.v0"
    },
    "source": {
      "type": "object",
      "required": ["text"],
      "additionalProperties": false,
      "properties": {
        "text": { "type": "string" },
        "language": { "type": "string" },
        "domain": { "type": "string" },
        "medium": { "type": "string" }
      }
    },
    "intent": {
      "$ref": "#/$defs/concept",
      "description": "The primary communicative act as a language-neutral concept."
    },
    "meaning": {
      "type": "object",
      "required": ["frames"],
      "additionalProperties": false,
      "properties": {
        "frames": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "type", "predicate"],
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string" },
              "type": {
                "type": "string",
                "description": "A coarse frame type, such as evaluation, claim, request, event, relation, or stance."
              },
              "predicate": {
                "$ref": "#/$defs/concept"
              },
              "arguments": {
                "type": "object",
                "additionalProperties": {
                  "$ref": "#/$defs/concept"
                }
              },
              "polarity": {
                "type": "string",
                "enum": ["positive", "negative", "neutral", "mixed", "unknown"]
              },
              "intensity": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "glosses": {
                "$ref": "#/$defs/localizedText"
              }
            }
          }
        },
        "glosses": {
          "$ref": "#/$defs/localizedText",
          "description": "Human-readable summaries for debugging and display. No language is canonical."
        },
        "open_questions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/concept"
          }
        }
      }
    },
    "affect": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "labels": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/concept"
          }
        },
        "intensity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "style": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "register": {
          "$ref": "#/$defs/concept"
        },
        "tone": {
          "$ref": "#/$defs/concept"
        },
        "formality": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "rhetorical_devices": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/concept"
          }
        }
      }
    },
    "culture": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "idioms": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/marker"
          }
        },
        "references": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/marker"
          }
        },
        "localization_notes": {
          "$ref": "#/$defs/localizedText"
        }
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source_language_markers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/marker"
          }
        },
        "sensitive_markers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/marker"
          }
        },
        "recommended_transform": {
          "$ref": "#/$defs/concept"
        }
      }
    },
    "targets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["language"],
        "additionalProperties": false,
        "properties": {
          "language": { "type": "string" },
          "audience": {
            "$ref": "#/$defs/localizedText"
          },
          "style": {
            "$ref": "#/$defs/concept"
          },
          "preserve_source_markers": { "type": "boolean" }
        }
      }
    }
  }
}
